<div class="pcm-config-body">
  <p class="hint">{{localize "PCM.Config.SecurityHint"}}</p>

  <div class="form-group">
    <label for="pcm-backend-url">{{localize "PCM.Settings.BackendUrl.Name"}}</label>
    <div class="form-fields">
      <input id="pcm-backend-url" name="backendUrl" type="url" value="{{backendUrl}}" required>
    </div>
    <p class="hint">{{localize "PCM.Settings.BackendUrl.Hint"}}</p>
  </div>

  <div class="form-group">
    <label for="pcm-api-key">{{localize "PCM.Settings.ApiKey.Name"}}</label>
    <div class="form-fields">
      <input id="pcm-api-key" name="apiKey" type="password" value="{{apiKey}}" autocomplete="off" required>
    </div>
    <p class="hint">{{localize "PCM.Settings.ApiKey.Hint"}}</p>
  </div>

  <div class="form-group">
    <label for="pcm-campaign-id">{{localize "PCM.Settings.CampaignId.Name"}}</label>
    <div class="form-fields">
      {{#if campaigns.length}}
        <select id="pcm-campaign-id" name="campaignId">
          <option value="">{{localize "PCM.Config.SelectCampaign"}}</option>
          {{#each campaigns}}
            <option value="{{id}}" {{#if (eq id ../campaignId)}}selected{{/if}}>{{name}} ({{current_year}})</option>
          {{/each}}
        </select>
      {{else}}
        <input id="pcm-campaign-id" name="campaignId" type="text" value="{{campaignId}}" placeholder="UUID">
      {{/if}}
      <button type="button" data-action="testConnection">
        <i class="fa-solid fa-plug"></i> {{localize "PCM.Config.Test"}}
      </button>
    </div>
    <p class="hint">{{localize "PCM.Settings.CampaignId.Hint"}}</p>
  </div>
</div>
