<div class="pcm-config-body">
  <p class="hint">{{localize "PCM.Config.SecurityHint"}}</p>

  <div class="form-group">
    <label for="pcm-backend-url">{{localize "PCM.Settings.BackendUrl.Name"}}</label>
    <div class="form-fields">
      <input id="pcm-backend-url" name="backendUrl" type="url" value="{{backendUrl}}" required>
    </div>
    <p class="hint">{{localize "PCM.Settings.BackendUrl.Hint"}}</p>
  </div>

  <div class="form-group">
    <label for="pcm-api-key">{{localize "PCM.Settings.ApiKey.Name"}}</label>
    <div class="form-fields">
      <input id="pcm-api-key" name="apiKey" type="password" value="" autocomplete="new-password" {{#unless apiKeyConfigured}}required{{/unless}}>
    </div>
    <p class="hint">{{localize "PCM.Settings.ApiKey.Hint"}}</p>
    {{#if apiKeyConfigured}}<p class="hint">{{localize "PCM.Settings.ApiKey.ConfiguredHint"}}</p>{{/if}}
    {{#if apiKeyConfigured}}
      <label class="checkbox"><input name="clearApiKey" type="checkbox"> {{localize "PCM.Settings.ApiKey.Clear"}}</label>
    {{/if}}
  </div>

  <div class="form-group">
    <label for="pcm-campaign-id">{{localize "PCM.Settings.CampaignId.Name"}}</label>
    <div class="form-fields">
      {{#if campaigns.length}}
        <select id="pcm-campaign-id" name="campaignId">
          <option value="">{{localize "PCM.Config.SelectCampaign"}}</option>
          {{#each campaigns}}
            <option value="{{id}}" {{#if (eq id ../campaignId)}}selected{{/if}}>{{name}} ({{current_year}})</option>
          {{/each}}
        </select>
      {{else}}
        <input id="pcm-campaign-id" name="campaignId" type="text" value="{{campaignId}}" placeholder="UUID">
      {{/if}}
      <button type="button" data-action="testConnection">
        <i class="fa-solid fa-plug"></i> {{localize "PCM.Config.Test"}}
      </button>
    </div>
    <p class="hint">{{localize "PCM.Settings.CampaignId.Hint"}}</p>
  </div>

  <fieldset class="pcm-create-campaign">
    <legend>{{localize "PCM.Config.CreateCampaign"}}</legend>
    <p class="hint">{{localize "PCM.Config.CreateCampaignHint"}}</p>

    <div class="form-group">
      <label for="pcm-new-campaign-name">{{localize "PCM.Config.CampaignName"}}</label>
      <div class="form-fields">
        <input id="pcm-new-campaign-name" name="newCampaignName" type="text" maxlength="200">
      </div>
    </div>

    <div class="form-group">
      <label for="pcm-new-campaign-slug">{{localize "PCM.Config.CampaignSlug"}}</label>
      <div class="form-fields">
        <input id="pcm-new-campaign-slug" name="newCampaignSlug" type="text" maxlength="100" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" placeholder="{{localize 'PCM.Config.CampaignSlugPlaceholder'}}">
      </div>
      <p class="hint">{{localize "PCM.Config.CampaignSlugHint"}}</p>
    </div>

    <div class="form-group">
      <label for="pcm-new-campaign-year">{{localize "PCM.Config.CampaignYear"}}</label>
      <div class="form-fields">
        <input id="pcm-new-campaign-year" name="newCampaignYear" type="number" value="485" min="1" max="9999" step="1">
      </div>
    </div>

    <div class="form-group stacked">
      <label for="pcm-new-campaign-description">{{localize "PCM.Config.CampaignDescription"}}</label>
      <textarea id="pcm-new-campaign-description" name="newCampaignDescription" rows="3"></textarea>
    </div>

    <button type="button" data-action="createCampaign">
      <i class="fa-solid fa-plus"></i> {{localize "PCM.Config.CreateAndSelect"}}
    </button>
  </fieldset>
</div>
